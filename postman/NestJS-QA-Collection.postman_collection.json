        {
          "name": "PATCH order status — invalid transition (negative)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/orders/{{order_id_terminal}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{order_id_terminal}}", "status"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Build a throwaway order and walk it all the way to DELIVERED",
                  "// (a terminal state) so the main request can attempt an invalid",
                  "// DELIVERED -> CANCELLED transition and assert 422.",
                  "const baseUrl = pm.environment.get('base_url');",
                  "const token = pm.environment.get('jwt_token');",
                  "",
                  "function patchStatus(orderId, status, cb) {",
                  "    pm.sendRequest({",
                  "        url: `${baseUrl}/api/orders/${orderId}/status`,",
                  "        method: 'PATCH',",
                  "        header: {",
                  "            'Content-Type': 'application/json',",
                  "            'Authorization': `Bearer ${token}`",
                  "        },",
                  "        body: { mode: 'raw', raw: JSON.stringify({ status }) }",
                  "    }, cb);",
                  "}",
                  "",
                  "pm.sendRequest({",
                  "    url: `${baseUrl}/api/orders`,",
                  "    method: 'POST',",
                  "    header: {",
                  "        'Content-Type': 'application/json',",
                  "        'Authorization': `Bearer ${token}`",
                  "    },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ productId: 1, quantity: 1 }) }",
                  "}, (err, res) => {",
                  "    if (err) { console.error(err); return; }",
                  "    const order = res.json();",
                  "    pm.environment.set('order_id_terminal', order.id);",
                  "",
                  "    patchStatus(order.id, 'CONFIRMED', (err2) => {",
                  "        if (err2) { console.error(err2); return; }",
                  "        patchStatus(order.id, 'DELIVERED', (err3) => {",
                  "            if (err3) { console.error(err3); }",
                  "        });",
                  "    });",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('cancelling a delivered order returns 422', function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test('error explains invalid transition', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
