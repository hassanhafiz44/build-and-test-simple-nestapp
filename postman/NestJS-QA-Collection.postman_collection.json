      "name": "Auth",
      "item": [
        {
          "name": "Register — happy path",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\",\n  \"name\": \"QA Tester\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a fresh email each time this folder/collection runs",
                  "pm.environment.set('test_email', `qatest_${Date.now()}@example.com`);",
                  "pm.environment.set('test_password', 'Test@12345');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register returns 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('response has id and email, never password', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('email');",
                  "    pm.expect(body).to.not.have.property('password');",
                  "});",
                  "",
                  "pm.test('email matches what we sent', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.email).to.eql(pm.environment.get('test_email'));",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.environment.set('user_id', body.id);"
                ]
              }
            }
          ],
          "response": []
        },
